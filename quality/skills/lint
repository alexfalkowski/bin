set -eo pipefail

missing=0

require_pattern() {
  local file="$1"
  local pattern="$2"

  if [[ ! -f "$file" ]]; then
    printf 'missing file: %s\n' "$file" >&2
    missing=1
    return
  fi

  if ! grep -Fq -- "$pattern" "$file"; then
    printf 'missing policy marker in %s: %s\n' "$file" "$pattern" >&2
    missing=1
  fi
}

require_ledger_core() {
  local file="$1"

