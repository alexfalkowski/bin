  require_pattern "$file" "#### Alternatives Considered"
  require_pattern "$file" "#### Definition of Success"
  require_pattern "$file" "**Validation:**"
  require_pattern "$file" "#### Situation Map"
}

reject_pattern() {
  local file="$1"
  local pattern="$2"

  if [[ ! -f "$file" ]]; then
    printf 'missing file: %s\n' "$file" >&2
    missing=1
    return
  fi

  if grep -Fq -- "$pattern" "$file"; then
    printf 'forbidden policy marker in %s: %s\n' "$file" "$pattern" >&2
    missing=1
  fi
}

reject_policy_tree_pattern() {
  local pattern="$1"

  if grep -FRq -- "$pattern" AGENTS.md skills; then
    printf 'forbidden policy marker in AGENTS.md or skills/: %s\n' "$pattern" >&2
    grep -FRn -- "$pattern" AGENTS.md skills >&2
    missing=1
  fi
}

require_reference() {
  local source="$1"
  local reference="$2"
  local resolved="${source%/*}/$reference"

  if [[ ! -f "$resolved" ]]; then
    printf 'missing relative reference in %s: %s\n' "$source" "$reference" >&2
    missing=1
  fi
}

