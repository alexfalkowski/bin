  require_pattern "$file" "### Why"
  require_pattern "$file" "**Impact.**"
  require_pattern "$file" "#### Evidence"
  require_pattern "$file" "**Claim:**"
  require_pattern "$file" "**Observed:**"
  require_pattern "$file" "**Reproduction:**"
  require_pattern "$file" "**Source:**"
  require_pattern "$file" "### How"
  require_pattern "$file" "#### Proposal"
