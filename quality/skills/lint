#!/usr/bin/env bash
# Check that agent policy hardening markers remain in shared skills.

set -eo pipefail

missing=0

require_pattern() {
  local file="$1"
  local pattern="$2"

  if [[ ! -f "$file" ]]; then
    printf 'missing file: %s\n' "$file" >&2
    missing=1
    return
  fi

  if ! grep -Fq -- "$pattern" "$file"; then
    printf 'missing policy marker in %s: %s\n' "$file" "$pattern" >&2
    missing=1
  fi
}

reject_pattern() {
  local file="$1"
  local pattern="$2"

  if [[ ! -f "$file" ]]; then
    printf 'missing file: %s\n' "$file" >&2
    missing=1
    return
  fi

  if grep -Fq -- "$pattern" "$file"; then
    printf 'forbidden policy marker in %s: %s\n' "$file" "$pattern" >&2
    missing=1
  fi
}

reject_policy_tree_pattern() {
  local pattern="$1"

  if grep -FRq -- "$pattern" AGENTS.md skills; then
    printf 'forbidden policy marker in AGENTS.md or skills/: %s\n' "$pattern" >&2
    grep -FRn -- "$pattern" AGENTS.md skills >&2
    missing=1
  fi
}

require_gitignore_pattern() {
  local pattern="$1"

  if [[ ! -f .gitignore ]]; then
    printf 'missing file: .gitignore\n' >&2
    missing=1
    return
  fi

  if ! grep -Fxq -- "$pattern" .gitignore; then
    printf 'missing .gitignore pattern: %s\n' "$pattern" >&2
    missing=1
  fi
}

