#!/usr/bin/env bash
# Check that agent policy hardening markers remain in shared skills.

set -eo pipefail

missing=0

require_pattern() {
  local file="$1"
  local pattern="$2"

  if [[ ! -f "$file" ]]; then
    printf 'missing file: %s\n' "$file" >&2
    missing=1
    return
  fi

  if ! grep -Fq -- "$pattern" "$file"; then
    printf 'missing policy marker in %s: %s\n' "$file" "$pattern" >&2
    missing=1
  fi
}

require_patterns() {
  local file="$1"
  local pattern

  while IFS= read -r pattern; do
    [[ -z "$pattern" ]] && continue
    require_pattern "$file" "$pattern"
  done
}

require_pattern_in_files() {
  local pattern="$1"
  shift

  local file
  for file in "$@"; do
    require_pattern "$file" "$pattern"
  done
}

require_ledger_core() {
  local file="$1"

  require_patterns "$file" <<'PATTERNS'
| Field | Value |
| Status |
**Summary.**
### What
**Current.**
**Expected.**
### Why
**Impact.**
#### Evidence
**Claim:**
**Observed:**
**Reproduction:**
**Source:**
### How
#### Proposal
**Keep.**
#### Alternatives Considered
#### Definition of Success
**Validation:**
#### Situation Map
PATTERNS
}

reject_pattern() {
  local file="$1"
  local pattern="$2"

  if [[ ! -f "$file" ]]; then
    printf 'missing file: %s\n' "$file" >&2
    missing=1
    return
  fi

  if grep -Fq -- "$pattern" "$file"; then
    printf 'forbidden policy marker in %s: %s\n' "$file" "$pattern" >&2
    missing=1
  fi
}

reject_patterns() {
  local file="$1"
  local pattern

  while IFS= read -r pattern; do
    [[ -z "$pattern" ]] && continue
    reject_pattern "$file" "$pattern"
  done
}

reject_pattern_in_files() {
  local pattern="$1"
  shift

  local file
  for file in "$@"; do
    reject_pattern "$file" "$pattern"
  done
}

reject_policy_tree_pattern() {
  local pattern="$1"

  if grep -FRq -- "$pattern" AGENTS.md skills; then
    printf 'forbidden policy marker in AGENTS.md or skills/: %s\n' "$pattern" >&2
    grep -FRn -- "$pattern" AGENTS.md skills >&2
    missing=1
  fi
}

reject_policy_tree_patterns() {
  local pattern

  while IFS= read -r pattern; do
    [[ -z "$pattern" ]] && continue
    reject_policy_tree_pattern "$pattern"
  done
}

require_reference() {
  local source="$1"
  local reference="$2"
  local resolved="${source%/*}/$reference"

  if [[ ! -f "$resolved" ]]; then
    printf 'missing relative reference in %s: %s\n' "$source" "$reference" >&2
    missing=1
  fi
}

