#!/usr/bin/env bash
# Scan a built test Docker image for critical vulnerabilities with Trivy.

set -eo pipefail

readonly name="$1"
readonly platform="$2"

# Scan using trivy.
trivy image --db-repository public.ecr.aws/aquasecurity/trivy-db:2 --exit-code 1 --severity CRITICAL "alexfalkowski/$name:test.$platform"
