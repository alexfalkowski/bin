{
  "defaultMode": "default",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "*"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "make",
      "make *"
    ],
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "/private/tmp",
        "/var/tmp",
        "/var/folders",
        "~/.cache/go-build",
        "~/.cache/rubocop_cache",
        "~/.cache/trivy",
        "~/Library/Caches/go-build",
        "~/Library/Caches/golangci-lint",
        "~/Library/Caches/trivy",
        "~/go/pkg/mod"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(make)",
      "Bash(make *)",
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "Read(//var/tmp/**)",
      "Read(//var/folders/**)",
      "Read(~/go/pkg/mod/**)",
      "Edit(//tmp/**)",
      "Edit(//private/tmp/**)",
      "Edit(//var/tmp/**)",
      "Edit(//var/folders/**)",
      "Write(//tmp/**)",
      "Write(//private/tmp/**)",
      "Write(//var/tmp/**)",
      "Write(//var/folders/**)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(make pr *)",
      "Bash(make draft *)",
      "Bash(make merge *)",
      "Bash(make ready *)",
      "Bash(make review *)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr reopen*)",
      "Bash(gh pr ready*)",
      "Bash(gh pr review*)",
      "Bash(gh pr comment*)",
      "Bash(gh issue create*)",
      "Bash(gh issue close*)",
      "Bash(gh issue edit*)",
      "Bash(gh issue reopen*)",
      "Bash(gh issue comment*)",
      "Bash(gh release create*)",
      "Bash(gh release delete*)",
      "Bash(gh release edit*)",
      "Bash(gh release upload*)",
      "Bash(gem push*)",
      "Bash(npm publish*)",
      "Bash(npm unpublish*)",
      "Bash(dd *)",
      "Bash(docker system prune*)",
      "Bash(docker rm*)",
      "Bash(docker rmi*)",
      "Bash(docker volume rm*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl create*)",
      "Bash(kubectl delete*)",
      "Bash(kubectl edit*)",
      "Bash(kubectl patch*)",
      "Bash(kubectl replace*)",
      "Bash(kubectl scale*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -fr /)",
      "Bash(rm -r /)",
      "Bash(rm -R /)",
      "Bash(rm -rf ~)",
      "Bash(rm -fr ~)",
      "Bash(rm -r ~)",
      "Bash(rm -R ~)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -fr $HOME)",
      "Bash(rm -r $HOME)",
      "Bash(rm -R $HOME)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(mkfs*)",
      "Bash(newfs*)",
      "Bash(dd *of=/dev/*)",
      "Bash(diskutil eraseDisk*)",
      "Bash(diskutil eraseVolume*)",
      "Bash(diskutil partitionDisk*)",
      "Bash(diskutil deleteVolume*)"
    ]
  }
}
