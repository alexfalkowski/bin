{
  "defaultMode": "acceptEdits",
  "sandbox": {
    "enabled": false
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Read(//**)",
      "Edit(**)",
      "Edit(//**)",
      "Write(**)",
      "Write(//**)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(make push*)",
      "Bash(make push-docker*)",
      "Bash(make proto-push*)",
      "Bash(make release-docker*)",
      "Bash(make new-release*)",
      "Bash(make manifest-docker*)",
      "Bash(make sync*)",
      "Bash(make force*)",
      "Bash(make reset*)",
      "Bash(make purge*)",
      "Bash(make delete*)",
      "Bash(make done*)",
      "Bash(make start*)",
      "Bash(make stop*)",
      "Bash(make pr*)",
      "Bash(make review*)",
      "Bash(make ready*)",
      "Bash(make draft*)",
      "Bash(make merge*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git rebase*)",
      "Bash(git branch -D*)",
      "Bash(git checkout --*)",
      "Bash(git restore*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr reopen*)",
      "Bash(gh pr ready*)",
      "Bash(gh pr review*)",
      "Bash(gh pr comment*)",
      "Bash(gh issue create*)",
      "Bash(gh issue close*)",
      "Bash(gh issue edit*)",
      "Bash(gh issue reopen*)",
      "Bash(gh issue comment*)",
      "Bash(gh release create*)",
      "Bash(gh release delete*)",
      "Bash(gh release edit*)",
      "Bash(gh release upload*)",
      "Bash(gem push*)",
      "Bash(npm publish*)",
      "Bash(npm unpublish*)",
      "Bash(dd *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r *)",
      "Bash(rm -R *)",
      "Bash(docker system prune*)",
      "Bash(docker rm*)",
      "Bash(docker rmi*)",
      "Bash(docker volume rm*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl create*)",
      "Bash(kubectl delete*)",
      "Bash(kubectl edit*)",
      "Bash(kubectl patch*)",
      "Bash(kubectl replace*)",
      "Bash(kubectl scale*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -fr /)",
      "Bash(rm -fr /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -fr ~)",
      "Bash(rm -fr ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(rm -fr $HOME)",
      "Bash(rm -fr $HOME/*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(mkfs*)",
      "Bash(newfs*)",
      "Bash(dd *of=/dev/*)",
      "Bash(diskutil eraseDisk*)",
      "Bash(diskutil eraseVolume*)",
      "Bash(diskutil partitionDisk*)",
      "Bash(diskutil deleteVolume*)"
    ]
  }
}
